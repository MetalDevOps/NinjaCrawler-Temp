{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NinjaCrawler",
  "version": "0.5.3",
  "identifier": "com.metaldevops.ninjacrawler",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NinjaCrawler",
        "width": 1650,
        "height": 950,
        "minWidth": 1320,
        "minHeight": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$HOME/Pictures/NinjaCrawler/**", "$LOCALAPPDATA/NinjaCrawler/**"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../connectors/bootstrap/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
