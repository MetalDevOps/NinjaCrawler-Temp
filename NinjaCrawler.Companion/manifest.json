{
  "manifest_version": 3,
  "name": "NinjaCrawler Companion",
  "description": "Adds supported social profiles from all open browser tabs and syncs them with NinjaCrawler.",
  "version": "0.17.0",
  "key": "",
  "action": {
    "default_popup": "popup.html",
    "default_title": "NinjaCrawler Companion",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://instagram.com/*",
        "https://www.instagram.com/*",
        "https://*.instagram.com/*"
      ],
      "js": [
        "src/storyNetworkHook.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://instagram.com/*",
        "https://www.instagram.com/*",
        "https://*.instagram.com/*"
      ],
      "js": [
        "src/storyDetection.js"
      ],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "activeTab",
    "cookies",
    "scripting",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "http://127.0.0.1:47219/*",
    "http://localhost:47219/*",
    "https://instagram.com/*",
    "https://*.instagram.com/*",
    "https://x.com/*",
    "https://*.x.com/*",
    "https://twitter.com/*",
    "https://*.twitter.com/*",
    "https://tiktok.com/*",
    "https://*.tiktok.com/*"
  ],
  "commands": {
    "sync-profile": {
      "description": "Sync the profile in the active tab"
    },
    "download-story": {
      "description": "Download the story in the active tab"
    }
  }
}
